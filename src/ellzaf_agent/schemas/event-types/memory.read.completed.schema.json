{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/ellzaf-agent/event-types/memory.read.completed.schema.json",
  "title": "memory.read.completed",
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "memory.read.completed" },
        "payload": {
          "type": "object",
          "required": ["memory_kind", "purpose"],
          "properties": {
            "memory_kind": { "type": "string", "minLength": 1 },
            "purpose": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
