{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/ellzaf-agent/event-types/llm.call.started.schema.json",
  "title": "llm.call.started",
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "llm.call.started" },
        "payload": {
          "type": "object",
          "required": ["provider", "model"],
          "properties": {
            "provider": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
