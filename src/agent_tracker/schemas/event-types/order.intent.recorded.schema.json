{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/agent-tracker/event-types/order.intent.recorded.schema.json",
  "title": "order.intent.recorded",
  "$defs": {
    "finiteNumber": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "pattern": "^[+-]?(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?$"
        }
      ]
    },
    "nullableFiniteNumber": {
      "anyOf": [{ "$ref": "#/$defs/finiteNumber" }, { "type": "null" }]
    }
  },
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "order.intent.recorded" },
        "payload": {
          "type": "object",
          "required": [
            "order_intent_id",
            "decision_id",
            "symbol",
            "side",
            "intended_quantity"
          ],
          "properties": {
            "order_intent_id": { "type": "string", "minLength": 1 },
            "decision_id": { "type": "string", "minLength": 1 },
            "symbol": { "type": "string", "minLength": 1 },
            "side": { "enum": ["buy", "sell", "short", "cover"] },
            "intended_quantity": { "$ref": "#/$defs/finiteNumber" },
            "intended_price": { "$ref": "#/$defs/nullableFiniteNumber" },
            "currency": { "type": ["string", "null"] },
            "open_close_effect": {
              "enum": ["open", "increase", "reduce", "close", "unknown", null]
            },
            "strategy_id": { "type": "string" },
            "setup": { "type": "string" },
            "session_date": { "type": "string", "format": "date" }
          }
        }
      }
    }
  ]
}
