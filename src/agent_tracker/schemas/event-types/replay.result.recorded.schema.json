{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/agent-tracker/event-types/replay.result.recorded.schema.json",
  "title": "replay.result.recorded",
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "replay.result.recorded" },
        "payload": {
          "type": "object",
          "required": ["suite_name", "status", "case_count"],
          "properties": {
            "suite_name": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "minLength": 1 },
            "case_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  ]
}
