{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/agent-tracker/event-types/performance.snapshot.recorded.schema.json",
  "title": "performance.snapshot.recorded",
  "$defs": {
    "finiteNumber": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "pattern": "^[+-]?(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?$"
        }
      ]
    },
    "nullableFiniteNumber": {
      "anyOf": [{ "$ref": "#/$defs/finiteNumber" }, { "type": "null" }]
    }
  },
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "performance.snapshot.recorded" },
        "payload": {
          "type": "object",
          "required": ["period_kind", "period_start", "period_end", "session_date"],
          "properties": {
            "period_kind": { "type": "string", "minLength": 1 },
            "period_start": { "type": "string", "format": "date" },
            "period_end": { "type": "string", "format": "date" },
            "session_date": { "type": "string", "format": "date" },
            "raw_equity_change": { "$ref": "#/$defs/nullableFiniteNumber" },
            "flow_adjusted_equity_change": {
              "$ref": "#/$defs/nullableFiniteNumber"
            },
            "trading_pnl_amount": { "$ref": "#/$defs/nullableFiniteNumber" },
            "trading_pnl_pct": { "$ref": "#/$defs/nullableFiniteNumber" },
            "net_pnl_amount": { "$ref": "#/$defs/nullableFiniteNumber" },
            "fees": { "$ref": "#/$defs/nullableFiniteNumber" },
            "fees_included": { "type": ["boolean", "null"] },
            "return_base": { "$ref": "#/$defs/nullableFiniteNumber" },
            "compounded_return_pct": { "$ref": "#/$defs/nullableFiniteNumber" },
            "max_drawdown_pct": { "$ref": "#/$defs/nullableFiniteNumber" }
          }
        }
      }
    }
  ]
}
