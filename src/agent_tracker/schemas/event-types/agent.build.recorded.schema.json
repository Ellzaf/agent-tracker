{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/agent-tracker/event-types/agent.build.recorded.schema.json",
  "title": "agent.build.recorded",
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "agent.build.recorded" },
        "payload": {
          "type": "object",
          "required": ["build_id", "config_hash", "risk_gate_version"],
          "properties": {
            "build_id": { "type": "string", "minLength": 1 },
            "config_hash": { "type": "string", "minLength": 1 },
            "risk_gate_version": { "type": "string", "minLength": 1 },
            "prompt_family": { "type": "string" },
            "prompt_version": { "type": "string" },
            "prompt_hash": { "type": "string" },
            "schema_version": { "type": "string" },
            "sdk_contract_version": { "type": "string" },
            "migration_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "changed_since_last_replay": { "type": "boolean" },
            "post_change_verification_required": { "type": "boolean" },
            "data_contract_status": {
              "enum": ["passed", "warning", "failed", "not_applicable"]
            }
          }
        }
      }
    }
  ]
}
