{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/agent-tracker/event-types/evaluation.epoch.member.completed.schema.json",
  "title": "evaluation.epoch.member.completed",
  "$defs": {
    "finiteNumber": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "pattern": "^[+-]?(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?$"
        }
      ]
    },
    "nonNegativeNumber": {
      "oneOf": [
        { "type": "number", "minimum": 0 },
        {
          "type": "string",
          "pattern": "^[+]?(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?$"
        }
      ]
    }
  },
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "evaluation.epoch.member.completed" },
        "payload": {
          "type": "object",
          "required": ["epoch_id", "member_id", "expected", "state"],
          "properties": {
            "epoch_id": { "type": "string", "minLength": 1 },
            "member_id": { "type": "string", "minLength": 1 },
            "expected": { "type": "boolean" },
            "state": {
              "enum": [
                "completed",
                "failed",
                "skipped",
                "timeout",
                "schema_failed",
                "not_runnable"
              ]
            },
            "context_hash": { "type": "string" },
            "input_snapshot_hash": { "type": "string" },
            "failure_bucket": { "type": "string" },
            "coverage_penalty": { "$ref": "#/$defs/nonNegativeNumber" },
            "scored": { "type": "boolean" }
          }
        }
      }
    }
  ]
}
