{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellzaf.com/schemas/agent-tracker/event-types/tool.call.completed.schema.json",
  "title": "tool.call.completed",
  "allOf": [
    { "$ref": "../event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "tool.call.completed" },
        "payload": {
          "type": "object",
          "required": ["tool_name", "status"],
          "properties": {
            "tool_name": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
